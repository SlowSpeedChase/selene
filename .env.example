# Selene Environment Configuration
# Copy to .env and override only what you need — every value below has a
# sensible default in src/lib/config.ts (or the workflow that reads it).

# --- Environment ---
SELENE_ENV=production                       # production | development | test

# --- Paths / Vault ---
# Curated Obsidian library written by export-obsidian:
SELENE_VAULT_PATH=/Users/you/Library/Mobile Documents/iCloud~md~obsidian/Documents/Selene
# Vault for the daily summary note (daily-summary.ts); often the same vault:
OBSIDIAN_VAULT_PATH=/Users/you/Library/Mobile Documents/iCloud~md~obsidian/Documents/Selene

# --- Ollama (local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Digest delivery ---
APPLE_NOTES_DIGEST_ENABLED=true             # "false" to disable
TRMNL_WEBHOOK_URL=https://usetrmnl.com/api/custom_plugins/YOUR_UUID  # e-ink; sends only when set
TRMNL_DIGEST_ENABLED=true

# --- Webhook server / Auth ---
PORT=5678
HOST=0.0.0.0
SELENE_API_TOKEN=                           # bearer token for ingestion (empty = auth off)
SELENE_WEBHOOK_URL=http://localhost:5678/webhook/api/drafts

# --- Workflow toggles ---
SELENE_REBUILD_CLUSTERS=                    # "1" forces cluster rebuild in synthesize-topics
THINGS_ENRICHER_PROJECT=Inbox               # Things project agent-manager files tasks into

# --- Advanced overrides (all have defaults; see src/lib/config.ts) ---
#   data paths: SELENE_DB_PATH SELENE_FACTS_DB_PATH SELENE_VECTORS_PATH SELENE_DIGESTS_PATH SELENE_LOGS_PATH
#   push: APNS_*   e-ink: EINK_*   voice: VOICE_*/WHISPER_*   logging: LOG_LEVEL
