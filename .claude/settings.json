{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-sync-check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATHS\" | grep -qE '(\\.env$|\\.env\\.|selene\\.db)'; then echo 'BLOCKED: Cannot edit .env files or production database' >&2; exit 2; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/prod-data-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-end-reminders.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATHS\" | grep -q '\\.ts$'; then cd /Users/chaseeasterling/selene && npx tsc --noEmit --pretty 2>&1 | head -20; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/test-run-warn.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-test-workflow.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATHS\" | grep -qE '(src/workflows/[^/]+\\.ts$|launchd/.*\\.plist$|scripts/install-(launchd|prod)\\.sh|scripts/deploy-prod\\.sh)'; then echo '{\"systemMessage\": \"LAUNCHD-SYNC: Workflow or plist file changed — invoke the launchd-auditor subagent to verify sync between src/workflows/, launchd/, and scripts/install-launchd.sh.\"}'; fi"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(/Users/chaseeasterling/selene-data/**)",
      "Edit(/Users/chaseeasterling/selene-data/**)",
      "Write(/Users/chaseeasterling/selene-data/**)",
      "Read(/Users/chaseeasterling/Library/Mobile Documents/iCloud~md~obsidian/Documents/Selene/**)",
      "Edit(/Users/chaseeasterling/Library/Mobile Documents/iCloud~md~obsidian/Documents/Selene/**)",
      "Write(/Users/chaseeasterling/Library/Mobile Documents/iCloud~md~obsidian/Documents/Selene/**)"
    ]
  }
}
